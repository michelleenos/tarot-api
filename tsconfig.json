{
    "compilerOptions": {
        "module": "esnext",
        "target": "esnext",
        "moduleResolution": "bundler",
        "types": [],

        // Recommended Options
        "strict": true,
        "verbatimModuleSyntax": true,
        "isolatedModules": true,
        "noUncheckedSideEffectImports": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "moduleDetection": "force",
        "skipLibCheck": true,

        "sourceMap": true,
        "noEmit": true
    }
}
