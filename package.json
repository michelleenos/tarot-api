{
    "name": "tarot-api",
    "version": "1.0.0",
    "description": "A REST API for tarot card data, including card meanings, suits, and random card draws.",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "dev": "tsx --watch src/index.ts",
        "lint": "eslint .",
        "build": "tsup src/index.ts --format esm",
        "serve": "node dist/index.js",
        "docker:build": "docker build -t tarot-api .",
        "docker:run": "docker run -p 8080:8080 -e PORT=8080 tarot-api",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage"
    },
    "keywords": [],
    "author": "Michelle Enos",
    "license": "ISC",
    "packageManager": "pnpm@10.6.3",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/express": "^5.0.6",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "4.1.6",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3",
        "supertest": "^7.2.2",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.58.2",
        "vitest": "^4.1.6"
    },
    "dependencies": {
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.1",
        "zod": "^4.4.1"
    }
}
